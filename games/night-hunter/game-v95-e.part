756246';ctx.strokeRect(item.x,item.y,item.w,item.h);ctx.beginPath();ctx.moveTo(item.x,item.y);ctx.lineTo(item.x+item.w,item.y+item.h);ctx.moveTo(item.x+item.w,item.y);ctx.lineTo(item.x,item.y+item.h);ctx.stroke()}else if(item.type==='elevatorConsole'){ctx.fillStyle='#0a1417';roundedPath(ctx,item.x,item.y,item.w,item.h,5);ctx.fill();ctx.fillStyle=state.generator?'#70ffc0':'#ff435f';ctx.shadowColor=ctx.fillStyle;ctx.shadowBlur=12;ctx.beginPath();ctx.arc(item.x+item.w/2,item.y+17,5,0,Math.PI*2);ctx.fill();ctx.shadowBlur=0}ctx.restore()}ctx.fillStyle='#05090a';ctx.fillRect(505,818,190,28);ctx.strokeStyle=state.generator?'#70ffc0':'#51686a';ctx.lineWidth=4;ctx.strokeRect(505,818,190,28);ctx.fillStyle=state.generator?'#70ffc055':'#ff435f22';ctx.fillRect(518,824,164,15)}
  function drawExtraDecor(now){ctx.save();ctx.strokeStyle='#4d747477';ctx.lineWidth=5;for(let x=850;x<1150;x+=55){ctx.beginPath();ctx.moveTo(x,604);ctx.lineTo(x,620);ctx.stroke()}ctx.strokeStyle='#ff435f55';ctx.lineWidth=2;ctx.beginPath();ctx.moveTo(476,73);ctx.lineTo(520,116);ctx.lineTo(485,150);ctx.stroke();ctx.fillStyle='#70ffc014';for(let i=0;i<4;i++){ctx.beginPath();ctx.arc(72+i*75,613,10,0,Math.PI*2);ctx.fill()}ctx.fillStyle='#ffc96b18';for(let i=0;i<5;i++){const x=875+i*50,y=260+Math.sin(now/380+i)*4;ctx.fillRect(x,y,18,4)}ctx.restore()}
  function drawSearchables(now){for(const item of searchables){if(state.searched.has(item.id))continue;const near=distance(player.x,player.y,item.x,item.y)<88,pulse=.55+.28*Math.sin(now/220);ctx.save();ctx.fillStyle=near?`rgba(127,255,233,${pulse})`:'#71918f';ctx.shadowColor='#7fffe9';ctx.shadowBlur=near?20:0;ctx.beginPath();ctx.arc(item.x,item.y,5,0,Math.PI*2);ctx.fill();ctx.shadowBlur=0;ctx.strokeStyle=near?'#7fffe988':'#526d6d55';ctx.beginPath();ctx.arc(item.x,item.y,near?17:10,0,Math.PI*2);ctx.stroke();ctx.restore()}}
  function drawObjectives(now){if(state.cards>=3&&!state.generator){ctx.strokeStyle=`rgba(112,255,192,${.5+.3*Math.sin(now/180)})`;ctx.lineWidth=3;ctx.beginPath();ctx.arc(generatorTarget.x,generatorTarget.y,25,0,Math.PI*2);ctx.stroke()}if(state.generator){ctx.strokeStyle=`rgba(112,255,192,${.55+.3*Math.sin(now/160)})`;ctx.lineWidth=3;ctx.beginPath();ctx.arc(elevatorTarget.x,elevatorTarget.y,27,0,Math.PI*2);ctx.stroke()}}
  function drawPlayer(now){if(state.hidden)return;ctx.save();ctx.translate(player.x,player.y);ctx.rotate(Math.atan2(player.facingY,player.facingX));const stride=Math.sin(now/85)*player.walk;ctx.fillStyle='#071014';ctx.strokeStyle='#8ad9cf';ctx.lineWidth=2;ctx.beginPath();ctx.arc(0,0,12,0,Math.PI*2);ctx.fill();ctx.stroke();ctx.strokeStyle='#426f70';ctx.lineWidth=4;ctx.beginPath();ctx.moveTo(-5,-7);ctx.lineTo(-13,-11-stride*4);ctx.moveTo(-5,7);ctx.lineTo(-13,11+stride*4);ctx.stroke();ctx.fillStyle='#a9fff2';ctx.beginPath();ctx.arc(5,-3,4,0,Math.PI*2);ctx.fill();ctx.fillStyle='#31595a';ctx.fillRect(-10,-8,7,16);ctx.fillStyle='#d9fff8';ctx.fillRect(9,-2,13,4);ctx.restore()}
  function drawMonster(now){const dist=distance(monster.x,monster.y,player.x,player.y),lit=isInFlashlight(monster.x,monster.y),visible=lit||monster.mode==='chase'||dist<105;ctx.save();ctx.translate(monster.x,monster.y);const angle=Math.atan2(player.y-monster.y,player.x-monster.x);ctx.rotate(angle);const stride=Math.sin(now/(monster.mode==='chase'?58:105)),breath=1+Math.sin(now/180)*.05;ctx.scale(breath,breath);ctx.globalAlpha=visible?1:dist<180?.46:.16;ctx.shadowColor='#000';ctx.shadowBlur=32;ctx.fillStyle='#010203';ctx.beginPath();ctx.ellipse(-3,0,18,35,-.12,0,Math.PI*2);ctx.fill();ctx.beginPath();ctx.ellipse(15,0,13,16,.18,0,Math.PI*2);ctx.fill();ctx.lineWidth=7;ctx.strokeStyle='#010203';ctx.beginPath();ctx.moveTo(-6,-15);ctx.quadraticCurveTo(-26,-23,-35,-39-stride*7);ctx.moveTo(-6,15);ctx.quadraticCurveTo(-27,22,-36,39+stride*7);ctx.stroke();ctx.lineWidth=4;ctx.beginPath();ctx.moveTo(-11,-20);ctx.lineTo(-24,-48);ctx.moveTo(-11,20);ctx.lineTo(-24,48);ctx.stroke();ctx.globalAlpha=lit||dist<190||monster.mode==='chase'?1:.5;ctx